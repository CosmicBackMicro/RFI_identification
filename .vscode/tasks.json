{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",  // 必须与launch.json的preLaunchTask一致
      "type": "shell",
      "command": "make",  // 调用make命令
      "args": ["-j4"],   // 可选：并行编译参数
      "options": {
        "cwd": "${workspaceFolder}"  // 指定工作目录为项目根目录
      },
      "problemMatcher": ["$gcc"],    // 捕获编译错误
      "group": {
        "kind": "build",
        "isDefault": true  // 设为默认构建任务（Ctrl+Shift+B触发）
      }
    }
  ]
}