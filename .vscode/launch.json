{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            // "preLaunchTask": "cmake-build",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/build/ReadFASTData",
            "args": [
                // "--filename=/mnt/d/FASTData/FITSFiles/G200.48+2.54_20250409_snapshot-M01-P1-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G200.14+2.80_20250409_snapshot-M05-P1-c1024b1.fits",
                "--filename=/mnt/d/FASTData/FITSFiles/G184.63-5.93_20210526_snapshot-M14-P4-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G152.35-2.20_20200104_snapshot-M05-P3-c2048b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G80.92-0.08_20210226_snapshot-M05-P4-c2048b1.fits",
                "--binFactorTime=1",
                "--binFactorFreq=1",
                "--plot=1",
                "--savePlot=1",
                "--write=1",
                "--writeBack=0",
                "--writeMasks=1",
                "--doSubstitution=1",
                "--doSumThreshold=1",
                "--blocksPerRead=1",
                "--startTime=0.0",
                "--generateMasks=1",
                "--datasetPath=/home/cbm/deRFI/output",
                "--enableCuda=0"
            ],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Debug via Shell Script",
            "type": "cppdbg",
            "request": "launch",
            "program": "/bin/bash",
            "args": [
                "${workspaceFolder}/run.sh"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "text": "set follow-fork-mode child",
                    "description": "跟踪 ReadFASTData 子进程"
                },
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
} 
// --filename=/mnt/d/FASTData/FITSFiles/G152.35-2.20_20200104_snapshot-M05-P3-c2048b1.fits --binFactorTime=1 --binFactorFreq=1 --plot=1 --savePlot=1 --write=1 --writeBack=0 --writeMasks=1 --doSubstitution=1 --doSumThreshold=1 --blocksPerRead=1 --startTime=0.0 --generateMasks=1 --datasetPath=/home/cbm/deRFI/output --enableCuda=0