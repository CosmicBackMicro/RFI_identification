{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            // "preLaunchTask": "cmake-build",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/build/ReadFASTData",
            "args": [
                // "--filename=/mnt/d/FASTData/FITSFiles/G204.84-1.61_20250112_snapshot-M13-P4-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G200.48+2.54_20250409_snapshot-M01-P1-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G191.19+2.54_20250408_snapshot-M05-P2-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/J195137+283648_20240726_tracking-M01-P1-c512b1.fits",
                // "--filename=/mnt/d/FASTData/G57.49-0.17_20190321_snapshot-M01-P1-c2048b1.fits",
                "--filename=/mnt/d/FASTData/FITSFiles/G200.14+2.80_20250409_snapshot-M05-P1-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/B0355+54_20191110_tracking_1-M01-P1-c2048b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G57.49-0.17_20211221_snapshot-M03-P2-c2048b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/B1929+10_20210106_tracking-M01-P1-c1024b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G65.07+1.10_20230604_snapshot-M12-P4-c2048b1.fits",
                // "--filename=/mnt/d/FASTData/FITSFiles/G200.53+2.97_20250409_snapshot-M01-P2-c1024b1.fits",
                
                // "--timeDuration=0.4",
                "--binFactorTime=1",
                "--binFactorFreq=1",
                "--plot=1",
                "--savePlot=1",
                "--write=1",
                "--doSubstitution=1",
                "--doSumThreshold=0",
                "--blocksPerRead=1",
                // "--blocksPerRead=1",
                "--startTime=0.0",
                "--generateMasks=1",
                "--datasetPath=/home/cbm/deRFI/output",
                "--enableCuda=1",
            ],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Debug via Shell Script",
            "type": "cppdbg",
            "request": "launch",
            "program": "/bin/bash",
            "args": [
                "${workspaceFolder}/run.sh"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "text": "set follow-fork-mode child",
                    "description": "跟踪 ReadFASTData 子进程"
                },
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
//  --filename=/mnt/d/FASTData/FITSFiles/J195137+283648_20240726_tracking-M01-P1-c512b1.fits --binFactorTime=1 --binFactorFreq=1 --plot=1 --write=1 --savePlot=1 --doSubstitution=1 --doSumThreshold=1 --blocksPerRead=8 --startTime=0.0 --generateMasks=1 --datasetPath=/home/cbm/deRFI/src/dataset